# Postgres (usado pelo docker-compose e pelo backend)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=gestao_financeira
POSTGRES_PORT=5433

# Backend
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/gestao_financeira?schema=public"
PORT=3000

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# E-mail (confirmação de conta e reset de senha)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=user@example.com
MAIL_PASSWORD=change-me
MAIL_FROM="Gestão Financeira para Casais <no-reply@example.com>"

# Frontend
FRONTEND_URL=http://localhost:5173
